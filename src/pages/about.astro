---
import BaseLayout from "../layouts/BaseLayout.astro";
import siteConfig from "../../site.config.json";
---

<BaseLayout title="About" description="About Gas City Hall and the team behind it.">
  <section class="page container">
    <h1 class="section-title">About Gas City Hall</h1>
    <div class="deco-divider"><span class="diamond"></span></div>

    <div class="glass-panel page-panel">
      <h2>What is Gas City Hall?</h2>
      <p>
        Gas City Hall is the community hub for
        <a href={siteConfig.social.github} target="_blank" rel="noopener">Gas City</a>, a fully
        customizable orchestration layer for AI coding agents. Gas City helps you track
        accountability, measure quality, and scale your AI-assisted engineering workflows. It works
        with Claude Code, Codex, Gemini, and more.
      </p>
      <p>
        Gas City evolved from Gas Town, adding complete customizability on top of the proven
        orchestration foundation. Out of the box it works like Gas Town, but you can define your own
        agents, formulas (orchestrations), standing orders (cron jobs), and build exactly the AI
        engineering workflow you need.
      </p>

      <h2>The Team</h2>
      <div class="team-grid">
        <div class="team-member">
          <img src="/images/rooster-chris.jpg" alt="Chris" width="280" height="350" />
          <h3>
            <a href="https://github.com/csells" target="_blank" rel="noopener">Chris Sells</a>
          </h3>
          <p>Gas Town Hall owner and proprietor</p>
        </div>
        <div class="team-member">
          <img src="/images/wolverine-julian.png" alt="Julian Knutsen" width="280" height="350" />
          <h3>
            <a href="https://github.com/julianknutsen" target="_blank" rel="noopener"
              >Julian Knutsen</a
            >
          </h3>
          <p>Gas City and Wasteland creator</p>
        </div>
      </div>

      <h2>Get Involved</h2>
      <p>
        Join the community on <a href={siteConfig.social.discord} target="_blank" rel="noopener"
          >Discord</a
        >, follow us on <a href={siteConfig.social.x} target="_blank" rel="noopener">X</a>, or
        contribute on <a href={siteConfig.social.github} target="_blank" rel="noopener">GitHub</a>.
      </p>

      <h2>Contact</h2>
      <p>
        For support, questions, or feedback, reach us at
        <a href="mailto:csells@gascity.ai">csells@gascity.ai</a>, on <a
          href={siteConfig.social.discord}
          target="_blank"
          rel="noopener">Discord</a
        >, or on <a href={siteConfig.social.x} target="_blank" rel="noopener">X</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .team-grid {
    display: flex;
    gap: 3rem;
    justify-content: center;
    margin: 1.5rem 0;
  }

  .team-member {
    text-align: center;
  }

  .team-member img {
    width: 280px;
    border-radius: 6px;
    margin-bottom: 0.75rem;
    border: 1px solid rgba(201, 168, 76, 0.25);
    filter: drop-shadow(0 0 20px rgba(201, 168, 76, 0.15));
  }

  .team-member h3 {
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .team-member h3 a {
    color: var(--gc-text-bright);
    transition: color 0.2s ease;
  }

  .team-member h3 a:hover {
    color: var(--gc-gold);
  }

  .team-member p {
    font-size: 1rem;
    color: var(--gc-text-dim);
  }
</style>
