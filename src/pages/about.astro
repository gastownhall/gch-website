---
import BaseLayout from "../layouts/BaseLayout.astro";
import siteConfig from "../../site.config.json";
---

<BaseLayout title="About" description="About Gas City Hall and the team behind it.">
  <section class="page container">
    <h1 class="section-title">About Gas City Hall</h1>
    <div class="deco-divider"><span class="diamond"></span></div>

    <div class="glass-panel page-panel">
      <h2>What is Gas City?</h2>
      <p>
        Gas City is a fully customizable orchestration layer for AI coding agents.
        It works with Claude Code, Codex, Gemini, and more. Define your own agents,
        create your own formulas (orchestrations), set up standing orders (cron jobs),
        and build exactly the AI engineering workflow you need.
      </p>
      <p>
        Gas City evolved from Gas Town, adding complete customizability on top of
        the proven orchestration foundation. Out of the box it works like Gas Town,
        but you can configure every aspect to match your team and workflow.
      </p>

      <h2>The Team</h2>
      <div class="team-grid">
        <div class="team-member">
          <img src="/images/rooster-chris.jpg" alt="Chris" width="120" height="150" />
          <h3>Chris Sells</h3>
          <p>Co-founder</p>
        </div>
        <div class="team-member">
          <img src="/images/wolverine-julian.png" alt="Julian" width="120" height="150" />
          <h3>Julian</h3>
          <p>Co-founder</p>
        </div>
      </div>

      <h2>Get Involved</h2>
      <p>
        Join the community on <a href={siteConfig.social.discord} target="_blank" rel="noopener">Discord</a>,
        follow us on <a href={siteConfig.social.x} target="_blank" rel="noopener">X</a>,
        or contribute on <a href={siteConfig.social.github} target="_blank" rel="noopener">GitHub</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .page-panel {
    padding: 2.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .page-panel h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--gc-gold);
    letter-spacing: 0.08em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .page-panel h2:first-child {
    margin-top: 0;
  }

  .page-panel p {
    color: var(--gc-text-dim);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .team-grid {
    display: flex;
    gap: 2rem;
    justify-content: center;
    margin: 1.5rem 0;
  }

  .team-member {
    text-align: center;
  }

  .team-member img {
    width: 120px;
    border-radius: 4px;
    margin-bottom: 0.5rem;
    filter: drop-shadow(0 0 15px rgba(201, 168, 76, 0.1));
  }

  .team-member h3 {
    font-size: 1rem;
    color: var(--gc-text-bright);
    margin-bottom: 0.2rem;
  }

  .team-member p {
    font-size: 0.85rem;
    color: var(--gc-text-dim);
  }

  @media (max-width: 768px) {
    .page-panel {
      padding: 1.5rem;
    }
  }
</style>
