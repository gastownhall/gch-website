---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Service" description="Gas City Hall terms of service.">
  <section class="page container">
    <h1 class="section-title">Terms of Service</h1>
    <div class="deco-divider"><span class="diamond"></span></div>

    <div class="glass-panel page-panel">
      <p class="updated">Last updated: March 19, 2026</p>

      <h2>Acceptance of Terms</h2>
      <p>
        By accessing gascityhall.com, you agree to be bound by these terms of
        service. If you do not agree with any part of these terms, please do not
        use this website.
      </p>

      <h2>Use of Service</h2>
      <p>
        Gas City Hall is a community hub and documentation site for Gas City, an
        open source AI agent orchestration platform. The content is provided for
        informational purposes.
      </p>

      <h2>Open Source</h2>
      <p>
        Gas City is open source software. Use of the Gas City software is governed
        by its respective license, available in the project repository.
      </p>

      <h2>Disclaimer</h2>
      <p>
        This website and its content are provided "as is" without warranty of any
        kind, express or implied.
      </p>

      <h2>Changes</h2>
      <p>
        We reserve the right to modify these terms at any time. Continued use of
        the site constitutes acceptance of modified terms.
      </p>
    </div>
  </section>
</BaseLayout>

