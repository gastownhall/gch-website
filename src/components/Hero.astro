---
import siteConfig from "../../site.config.json";
---

<section class="hero container">
  <h1 class="section-title">Gas City Hall</h1>
  <div class="deco-divider"><span class="diamond"></span></div>

  <div class="hero-inner">
    <div class="hero-mascots">
      <img
        src="/images/mascots.webp"
        alt="Chris the Rooster and Julian the Wolverine"
        class="mascot-duo"
        width="320"
        height="179"
      />
    </div>
    <div class="hero-content">
      <p class="hero-tagline">Your city. Your rules.</p>
      <p class="hero-description">
        Fully customizable AI agent orchestration. Works with Claude Code, Codex, Gemini and more.
      </p>
      <div class="hero-actions">
        <a href={siteConfig.site.docsUrl} target="_blank" rel="noopener" class="btn btn-primary">
          Get Started
        </a>
        <a
          href={siteConfig.social.discord}
          target="_blank"
          rel="noopener"
          class="btn btn-secondary"
        >
          Join Discord
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
  }

  .hero-mascots {
    flex-shrink: 0;
  }

  .mascot-duo {
    filter: drop-shadow(0 0 20px rgba(201, 168, 76, 0.15));
    width: 320px;
    height: auto;
  }

  .hero-content {
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--gc-text-bright);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .hero-description {
    color: var(--gc-text-dim);
    font-size: 1.05rem;
    font-weight: 300;
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .hero-mascots {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 0 2rem;
      text-align: center;
    }

    .hero-inner {
      flex-direction: column;
    }

    .hero-tagline {
      font-size: 1.3rem;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
