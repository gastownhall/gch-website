---

---

<section class="leaderboard container">
  <h2 class="section-title">Wasteland Leaderboard</h2>
  <p class="section-subtitle">Live scoreboard from the Wasteland</p>

  <div class="glass-panel leaderboard-panel">
    <div id="leaderboard-loading" class="leaderboard-state">
      <div class="spinner"></div>
      <p>Loading scoreboard...</p>
    </div>

    <div id="leaderboard-error" class="leaderboard-state" style="display:none">
      <p>Unable to load scoreboard data.</p>
      <a href="https://wasteland.gastownhall.ai" target="_blank" rel="noopener" class="error-link">
        Visit the Wasteland directly &rarr;
      </a>
    </div>

    <!-- Desktop table -->
    <table id="leaderboard-table" style="display:none">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th class="col-rig">Rig</th>
          <th class="col-tier">Tier</th>
          <th class="col-num">Score</th>
          <th class="col-num">Stamps</th>
          <th class="col-num">Done</th>
          <th class="col-skills">Skills</th>
        </tr>
      </thead>
      <tbody id="leaderboard-body"></tbody>
    </table>

    <!-- Mobile cards -->
    <div id="leaderboard-cards" style="display:none"></div>
  </div>

  <p class="leaderboard-updated" id="leaderboard-updated"></p>

  <div class="leaderboard-cta">
    <a href="https://wasteland.gastownhall.ai" target="_blank" rel="noopener" class="btn-outline">
      Visit the Wasteland &rarr;
    </a>
  </div>
</section>

<script>
  const TIER_MAP: Record<string, { label: string; color: string }> = {
    imperator: { label: "Imperator", color: "#e8c84a" },
    warrior: { label: "Warrior", color: "#b8862d" },
    settler: { label: "Settler", color: "#b8c0cc" },
    scavenger: { label: "Scavenger", color: "#8a92a1" },
    drifter: { label: "Drifter", color: "#6a6660" },
  };

  interface ScoreboardEntry {
    rig_handle: string;
    display_name: string;
    trust_tier: string;
    stamp_count: number;
    weighted_score: number;
    completions: number;
    top_skills: string[];
  }

  function createTierBadge(tierKey: string): HTMLSpanElement {
    const tier = TIER_MAP[tierKey?.toLowerCase()] || TIER_MAP.drifter;
    const badge = document.createElement("span");
    badge.className = "tier-badge";
    badge.style.color = tier.color;
    badge.style.borderColor = tier.color;
    badge.textContent = tier.label;
    return badge;
  }

  function profileUrl(handle: string): string {
    return `https://wasteland.gastownhall.ai/profile/${handle}`;
  }

  function buildTableRow(entry: ScoreboardEntry, rank: number): HTMLTableRowElement {
    const tr = document.createElement("tr");
    tr.className = rank <= 3 ? `rank-${rank}` : "rank-default";
    tr.addEventListener("click", () => window.open(profileUrl(entry.rig_handle), "_blank"));

    const tdRank = document.createElement("td");
    tdRank.className = "col-rank";
    tdRank.textContent = String(rank);
    tr.appendChild(tdRank);

    const tdRig = document.createElement("td");
    tdRig.className = "col-rig";
    const nameSpan = document.createElement("span");
    nameSpan.className = "entry-display-name";
    nameSpan.textContent = entry.display_name || entry.rig_handle;
    tdRig.appendChild(nameSpan);
    const handleSpan = document.createElement("span");
    handleSpan.className = "entry-handle";
    handleSpan.textContent = `@${entry.rig_handle}`;
    tdRig.appendChild(handleSpan);
    tr.appendChild(tdRig);

    const tdTier = document.createElement("td");
    tdTier.className = "col-tier";
    tdTier.appendChild(createTierBadge(entry.trust_tier));
    tr.appendChild(tdTier);

    for (const val of [entry.weighted_score, entry.stamp_count, entry.completions]) {
      const td = document.createElement("td");
      td.className = "col-num";
      td.textContent = String(val);
      tr.appendChild(td);
    }

    const tdSkills = document.createElement("td");
    tdSkills.className = "col-skills";
    const skills = (entry.top_skills || []).slice(0, 3).join(", ");
    tdSkills.textContent = skills || "\u2014";
    tr.appendChild(tdSkills);

    return tr;
  }

  function buildCard(entry: ScoreboardEntry, rank: number): HTMLDivElement {
    const card = document.createElement("div");
    card.className = `lb-card ${rank <= 3 ? `rank-${rank}` : "rank-default"}`;
    card.addEventListener("click", () => window.open(profileUrl(entry.rig_handle), "_blank"));

    const header = document.createElement("div");
    header.className = "lb-card-header";

    const rankSpan = document.createElement("span");
    rankSpan.className = "lb-card-rank";
    rankSpan.textContent = String(rank);
    header.appendChild(rankSpan);

    const nameWrap = document.createElement("div");
    nameWrap.className = "lb-card-name-wrap";
    const rigSpan = document.createElement("span");
    rigSpan.className = "lb-card-rig";
    rigSpan.textContent = entry.display_name || entry.rig_handle;
    nameWrap.appendChild(rigSpan);
    const handleSpan = document.createElement("span");
    handleSpan.className = "lb-card-handle";
    handleSpan.textContent = `@${entry.rig_handle}`;
    nameWrap.appendChild(handleSpan);
    header.appendChild(nameWrap);

    header.appendChild(createTierBadge(entry.trust_tier));
    card.appendChild(header);

    const stats = document.createElement("div");
    stats.className = "lb-card-stats";
    for (const [label, val] of [
      ["Score", entry.weighted_score],
      ["Stamps", entry.stamp_count],
      ["Done", entry.completions],
    ] as const) {
      const span = document.createElement("span");
      const strong = document.createElement("strong");
      strong.textContent = String(val);
      span.textContent = `${label}: `;
      span.appendChild(strong);
      stats.appendChild(span);
    }
    card.appendChild(stats);

    const skills = (entry.top_skills || []).slice(0, 3).join(", ");
    if (skills) {
      const skillsDiv = document.createElement("div");
      skillsDiv.className = "lb-card-skills";
      skillsDiv.textContent = skills;
      card.appendChild(skillsDiv);
    }

    return card;
  }

  async function loadLeaderboard() {
    const loading = document.getElementById("leaderboard-loading")!;
    const error = document.getElementById("leaderboard-error")!;
    const table = document.getElementById("leaderboard-table")!;
    const cards = document.getElementById("leaderboard-cards")!;
    const tbody = document.getElementById("leaderboard-body")!;
    const updatedEl = document.getElementById("leaderboard-updated")!;

    const res = await fetch("https://wasteland.gastownhall.ai/api/scoreboard");
    const json = await res.json();
    const data: ScoreboardEntry[] = json.entries || [];

    loading.style.display = "none";

    if (data.length === 0) {
      error.style.display = "flex";
      return;
    }

    data.sort((a, b) => b.weighted_score - a.weighted_score || b.stamp_count - a.stamp_count);

    data.forEach((entry, i) => {
      const rank = i + 1;
      tbody.appendChild(buildTableRow(entry, rank));
      cards.appendChild(buildCard(entry, rank));
    });

    if (json.updated_at) {
      const date = new Date(json.updated_at);
      updatedEl.textContent = `Last updated: ${date.toLocaleDateString()} ${date.toLocaleTimeString()}`;
    }

    table.style.display = "";
    cards.style.display = "";
  }

  loadLeaderboard().catch(() => {
    document.getElementById("leaderboard-loading")!.style.display = "none";
    document.getElementById("leaderboard-error")!.style.display = "flex";
  });
</script>

<style is:global>
  .leaderboard {
    margin-top: var(--section-gap);
  }

  .leaderboard-panel {
    padding: 1.5rem;
    overflow-x: auto;
  }

  .leaderboard-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem 1rem;
    color: var(--gc-text-dim);
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid rgba(201, 168, 76, 0.2);
    border-top-color: var(--gc-gold);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .error-link {
    color: var(--gc-gold);
    font-size: 1.05rem;
  }

  /* Table */
  .leaderboard table {
    width: 100%;
    border-collapse: collapse;
  }

  .leaderboard th {
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gc-text-dim);
    padding: 0.75rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid rgba(201, 168, 76, 0.15);
  }

  .leaderboard td {
    padding: 0.6rem 0.5rem;
    font-size: 1.05rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .leaderboard tr {
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .leaderboard tr:hover {
    background: rgba(201, 168, 76, 0.06);
  }

  .rank-1 {
    background: rgba(232, 200, 74, 0.05);
  }
  .rank-2 {
    background: rgba(184, 192, 204, 0.05);
  }
  .rank-3 {
    background: rgba(184, 134, 45, 0.05);
  }

  .leaderboard .col-rank {
    width: 3rem;
    text-align: center;
  }
  .leaderboard .col-tier {
    text-align: center;
  }
  .leaderboard .col-num {
    text-align: center;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .entry-display-name {
    font-weight: 600;
    display: block;
  }

  .entry-handle {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    color: var(--gc-text-dim);
    display: block;
  }

  .col-skills {
    font-family: var(--font-mono, monospace);
    font-size: 0.9rem;
    color: var(--gc-text-dim);
  }

  .leaderboard-updated {
    text-align: right;
    font-size: 0.9rem;
    color: var(--gc-text-dim);
    font-style: italic;
    margin-top: 0.5rem;
  }

  .tier-badge {
    display: inline-block;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border: 1px solid;
    border-radius: 2px;
  }

  /* Mobile cards */
  #leaderboard-cards {
    display: none !important;
  }

  .lb-card {
    display: block;
    padding: 1rem;
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    color: var(--gc-text);
    transition: background 0.15s ease;
  }

  .lb-card:hover {
    background: rgba(201, 168, 76, 0.06);
    color: var(--gc-text);
  }

  .lb-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .lb-card-rank {
    font-size: 1.1rem;
    min-width: 2rem;
  }

  .lb-card-name-wrap {
    flex: 1;
  }

  .lb-card-rig {
    font-weight: 600;
    display: block;
  }

  .lb-card-handle {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    color: var(--gc-text-dim);
    display: block;
  }

  .lb-card-skills {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    color: var(--gc-text-dim);
    padding-left: 2.75rem;
    margin-top: 0.25rem;
  }

  .lb-card-stats {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
    color: var(--gc-text-dim);
    padding-left: 2.75rem;
  }

  /* CTA */
  .leaderboard-cta {
    text-align: center;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    table,
    #leaderboard-table {
      display: none !important;
    }

    #leaderboard-cards {
      display: block !important;
    }

    .lb-card-stats {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }
</style>
