---
import siteConfig from "../../site.config.json";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string;
  modifiedDate?: string;
}

const {
  title,
  description,
  image = "/images/gc-logo-og.png",
  type = "website",
  publishedDate,
  modifiedDate,
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.site.name}` : siteConfig.site.name;
const pageDescription = description || siteConfig.site.description;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.site.url).href;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

// JSON-LD Structured Data
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.site.name,
  url: siteConfig.site.url,
  logo: `${siteConfig.site.url}/images/gc-logo-og.png`,
  sameAs: [siteConfig.social.github, siteConfig.social.x, siteConfig.social.discord],
  contactPoint: {
    "@type": "ContactPoint",
    email: "csells@gascity.ai",
    contactType: "support",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.site.name,
  url: siteConfig.site.url,
  description: siteConfig.site.description,
  publisher: {
    "@type": "Organization",
    name: siteConfig.site.name,
  },
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  ...(publishedDate && { datePublished: publishedDate }),
  ...(modifiedDate && { dateModified: modifiedDate }),
  publisher: {
    "@type": "Organization",
    name: siteConfig.site.name,
    url: siteConfig.site.url,
  },
};

const schemas = isHomePage ? [organizationSchema, websiteSchema, webPageSchema] : [webPageSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />

    <!-- SEO Meta Tags -->
    <meta name="robots" content="index, follow" />
    <meta
      name="googlebot"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="author" content="Chris Sells" />
    <meta
      name="keywords"
      content="Gas City, AI coding agents, orchestration, developer tools, AI workflow, coding automation"
    />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/images/gc-logo-180.png" />
    <link rel="preload" as="image" href="/images/hero-bg.webp" />

    <!-- RSS Feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteConfig.site.name} Blog`}
      href="/rss.xml"
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Raleway:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`${siteConfig.site.url}${image}`} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Gas City Hall — AI agent orchestration hub" />
    <meta property="og:site_name" content={siteConfig.site.name} />
    <meta property="og:locale" content="en_US" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteConfig.site.url}${image}`} />
    <meta name="twitter:site" content={siteConfig.site.twitterHandle} />
    <meta name="twitter:creator" content="@csells" />

    <!-- JSON-LD Structured Data -->
    {
      schemas.map((schema) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <!-- Plausible Analytics -->
    <script
      is:inline
      defer
      data-domain={siteConfig.analytics.plausibleDomain}
      src={siteConfig.analytics.plausibleScript}></script>

    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">
          <img src="/images/gc-logo.png" alt="Gas City Hall" width="40" height="40" />
          <span class="site-name">Gas City Hall</span>
        </a>
        <nav class="site-nav">
          <a href="https://wasteland.gastownhall.ai" target="_blank" rel="noopener">Wasteland</a>
          <a href={siteConfig.site.docsUrl} target="_blank" rel="noopener">Docs</a>
          <a href={siteConfig.social.discord} target="_blank" rel="noopener" aria-label="Discord">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
              ></path></svg
            >
          </a>
          <a href={siteConfig.social.x} target="_blank" rel="noopener" aria-label="X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </a>
          <a href={siteConfig.social.github} target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-links">
          <a href="/privacy">Privacy</a>
          <span class="footer-sep">|</span>
          <a href="/terms">Terms</a>
          <span class="footer-sep">|</span>
          <a href="/about">About</a>
        </div>
        <p class="footer-copy">
          &copy; {new Date().getFullYear()} Gas City Hall. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ============================
     GAS CITY HALL — ART DECO THEME
     Phase 3: Chrome, Glass, Neon
     Warm amber undertones persist
     ============================ */

  :root {
    /* Core palette */
    --gc-black: #0a0a0f;
    --gc-dark: #121218;
    --gc-surface: #1a1a24;
    --gc-surface-light: #22222e;

    /* Metals */
    --gc-gold: #c9a84c;
    --gc-gold-bright: #e8c84a;
    --gc-chrome: #b8c0cc;
    --gc-silver: #8a92a1;

    /* Accents */
    --gc-blue: #4a7fb5;
    --gc-blue-glow: #5c9fd4;
    --gc-amber: #b8862d;
    --gc-amber-warm: #d4a03c;
    --gc-neon: #6bb5cc;

    /* Text */
    --gc-text: #f0ece4;
    --gc-text-dim: #c8c2b6;
    --gc-text-bright: #f8f4ec;

    /* Discord */
    --gc-discord: #5865f2;

    /* Fonts */
    --font-display: "Cinzel", "Didot", serif;
    --font-body: "Raleway", "Helvetica Neue", sans-serif;
    --font-mono: "JetBrains Mono", monospace;

    /* Spacing */
    --container-max: 1100px;
    --section-gap: 4rem;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.2rem;
    color: var(--gc-text);
    background: var(--gc-black);
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Background image */
  body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: url("/images/hero-bg.webp") center center / cover no-repeat;
    opacity: 0.18;
    z-index: -1;
    pointer-events: none;
  }

  a {
    color: var(--gc-gold);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--gc-gold-bright);
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* ---- Deco Divider ---- */
  .deco-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 2rem 0;
  }

  .deco-divider::before,
  .deco-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--gc-gold) 20%,
      var(--gc-gold) 80%,
      transparent
    );
    opacity: 0.4;
  }

  .deco-divider .diamond {
    width: 8px;
    height: 8px;
    background: var(--gc-gold);
    transform: rotate(45deg);
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ---- Section styling ---- */
  .section-title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--gc-gold);
    text-align: center;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--gc-text-dim);
    font-weight: 300;
    font-size: 1.15rem;
    margin-bottom: 2rem;
  }

  /* ---- Glass panel ---- */
  .glass-panel {
    background: linear-gradient(135deg, rgba(26, 26, 36, 0.9), rgba(18, 18, 24, 0.95));
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 4px;
    backdrop-filter: blur(10px);
  }

  /* ---- Container ---- */
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Page layout (about, privacy, terms) ---- */
  .page {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .page-panel {
    padding: 2.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .page-panel h2 {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--gc-gold);
    letter-spacing: 0.08em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .page-panel h2:first-child {
    margin-top: 0;
  }

  .page-panel p {
    color: var(--gc-text-dim);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .updated {
    font-size: 1rem;
    color: var(--gc-silver);
    margin-bottom: 1.5rem;
  }

  /* ---- Buttons ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.8rem;
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 3px;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gc-gold), var(--gc-amber));
    color: var(--gc-black);
    border: 1px solid var(--gc-gold);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--gc-gold-bright), var(--gc-gold));
    color: var(--gc-black);
    box-shadow: 0 0 20px rgba(201, 168, 76, 0.3);
  }

  .btn-secondary {
    background: transparent;
    color: var(--gc-text);
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .btn-secondary:hover {
    border-color: var(--gc-gold);
    color: var(--gc-gold);
    box-shadow: 0 0 15px rgba(201, 168, 76, 0.1);
  }

  .btn-outline {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gc-gold);
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: 3px;
    transition: all 0.25s ease;
  }

  .btn-outline:hover {
    border-color: var(--gc-gold);
    box-shadow: 0 0 15px rgba(201, 168, 76, 0.15);
    color: var(--gc-gold-bright);
  }

  @media (max-width: 768px) {
    :root {
      --section-gap: 2.5rem;
    }

    body::before {
      background-image: url("/images/hero-bg.webp");
      opacity: 0.15;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .page-panel {
      padding: 1.5rem;
    }
  }
</style>

<style>
  /* ---- Header ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.15);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--gc-text-bright);
  }

  .site-logo:hover {
    color: var(--gc-gold);
  }

  .site-logo img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
  }

  .site-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-nav a {
    color: var(--gc-text-dim);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
  }

  .site-nav a:hover {
    color: var(--gc-gold);
  }

  /* ---- Footer ---- */
  .site-footer {
    border-top: 1px solid rgba(201, 168, 76, 0.15);
    margin-top: var(--section-gap);
    padding: 2rem 0;
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .footer-links {
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    color: var(--gc-text-dim);
    font-size: 1rem;
  }

  .footer-links a:hover {
    color: var(--gc-gold);
  }

  .footer-sep {
    color: rgba(201, 168, 76, 0.3);
    margin: 0 0.75rem;
  }

  .footer-copy {
    color: var(--gc-text-dim);
    font-size: 0.95rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .site-name {
      font-size: 1.1rem;
    }

    .site-nav {
      gap: 1rem;
    }

    .site-nav a {
      font-size: 0.95rem;
    }
  }
</style>
