{
  "name": "gc-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler pages deploy deploy --project-name=gch-website",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:check": "npm audit --audit-level=info",
    "check": "npm run lint && npm run format:check && npm run build && npm run audit:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.53.1",
    "wrangler": "^4.75.0"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
